{
  "manifest_version": 3,
  "name": "ぞうさん薬局 - 薬名転写 [DEV]",
  "version": "0.7.0",
  "description": "[DEV版] 本番(drug-ocr-extension)と独立した開発用フォーク。転記機能改修中。",
  "permissions": ["scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["https://okusuri.duckdns.org/*", "https://*/*"],
  "action": {
    "default_title": "ぞうさん薬局 [DEV]"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
